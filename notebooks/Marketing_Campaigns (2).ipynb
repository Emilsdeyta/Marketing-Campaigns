      "source": [
        "## Difference-in-Differences (DiD)"
      ],
      "metadata": {
        "id": "eeAgm-C59y6j"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "pre = df1[df1['post'] == 0]\n",
        "\n",
        "ts_pre = pre.groupby(['Date', 'Treated'])['Sales'].mean().reset_index()\n",
        "\n",
        "treated_pre = ts_pre[ts_pre['Treated'] == 1]\n",
        "control_pre = ts_pre[ts_pre['Treated'] == 0]"
