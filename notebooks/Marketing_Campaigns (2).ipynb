    {
      "cell_type": "code",
      "source": [
        "from sklearn.linear_model import LinearRegression\n",
        "treated_pre['t'] = range(len(treated_pre))\n",
        "control_pre['t'] = range(len(control_pre))\n",
        "\n",
        "model_t = LinearRegression().fit(treated_pre[['t']], treated_pre['Sales'])\n",
        "model_c = LinearRegression().fit(control_pre[['t']], control_pre['Sales'])\n",
        "\n",
        "print(\"Treated slope:\", model_t.coef_)\n",
        "print(\"Control slope:\", model_c.coef_)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
