      "source": [
        "# Log Sales\n",
        "df['log_sales'] = np.log1p(df['Sales'])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 31,
      "metadata": {
        "id": "3QyTuewaSnKj"
      },
      "outputs": [],
      "source": [
        "cap = df['Sales'].quantile(0.99)\n",
        "df['Sales_Clipped'] = df['Sales'].clip(upper=cap)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 32,
      "metadata": {
        "id": "vuREqcm9SnKk"
      },
      "outputs": [],
      "source": [
        "cutoff_date = df['Date'].quantile(0.60)\n",
        "df['post'] = (df['Date']>=cutoff_date).astype(int)"
      ]
    },
