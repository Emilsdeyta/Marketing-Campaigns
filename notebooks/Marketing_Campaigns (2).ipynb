            "X-Learner -329.6399079452042\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "`# S-Learner:  -157\n",
        "# T-Learner:  -270\n",
        "# X-Learner:  -288\n",
        "# Hamısı deyir ki kompaniya satışaları azaldıb 3də negativdir"
      ],
      "metadata": {
        "id": "06-wJkb19wXi"
