        "def describe(df):\n",
        "  A = []\n",
        "  columns = df.columns\n",
        "\n",
        "  for i in columns:\n",
        "    isnull = df[i].isnull().sum()\n",
        "    unique = df[i].nunique()\n",
        "    dtype = df[i].dtype\n",
        "    A.append([i,isnull, unique, dtype])\n",
        "\n",
        "  dff = pd.DataFrame(A, columns=['columns', 'isnull', 'unique', 'dtype'])\n",
        "  return dff\n",
        "\n",
        "print(describe(df))"
      ]
