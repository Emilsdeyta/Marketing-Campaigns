      "execution_count": 43,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "plt.figure()\n",
        "plt.plot(treated_pre['Date'], treated_pre['Sales'], label='Treated')\n",
        "plt.plot(control_pre['Date'], control_pre['Sales'], label='Control')\n",
        "plt.legend()\n",
        "plt.title(\"Parallel Trend Yoxlanmasi\")\n",
        "plt.xticks(rotation=45)\n",
        "plt.show()"
