    {
      "cell_type": "code",
      "source": [
        "# DID Regression\n",
        "import statsmodels.formula.api as smf\n",
        "\n",
        "# model\n",
        "model = smf.ols(\n",
        "    'Sales ~ Treated * post + Clicks + Impressions + Engagement_Score + Acquisition_Cost',\n",
        "    data=df1\n",
        ").fit()\n",
        "\n",
        "print(model.summary())\n",
        "\n",
        "\n",
        "ate = model.params['Treated:post']\n",
        "print(ate)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
