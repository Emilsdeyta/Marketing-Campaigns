    {
      "cell_type": "markdown",
      "source": [
        "## EconML"
      ],
      "metadata": {
        "id": "ByIQ0jD3_Mm0"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.ensemble import RandomForestRegressor\n",
        "\n",
        "X = df1[['Clicks','Impressions','Engagement_Score','Acquisition_Cost']]\n",
        "T = df1['Treated']\n",
        "Y = df1['Sales']      # log_sales secdikde neticeler daha yaxsi olur\n",
        "\n",
        "# S learner T ni feature kimi daxil edirik\n",
        "X_s = X.copy()\n",
        "X_s['Treated'] = T\n",
        "\n",
        "model_s = RandomForestRegressor()\n",
        "model_s.fit(X_s, Y)\n",
        "\n",
        "# prediction fərqi\n",
        "X1 = X.copy()\n",
        "X1['Treated'] = 1\n",
        "\n",
        "X0 = X.copy()\n",
        "X0['Treated'] = 0\n",
        "\n",
        "effect_s = model_s.predict(X1) - model_s.predict(X0)\n",
        "\n",
        "print(\"S-Learner\", effect_s.mean())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "0tC2sRw29wOx",
        "outputId": "fd21d2a5-a884-48d0-ade8-ca6402f55472"
      },
      "execution_count": 72,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "S-Learner -104.67464438355927\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "model_treated = RandomForestRegressor()\n",
        "model_control = RandomForestRegressor()\n",
        "\n",
        "model_treated.fit(X[T==1], Y[T==1])\n",
        "model_control.fit(X[T==0], Y[T==0])\n",
        "\n",
        "effect_t = model_treated.predict(X) - model_control.predict(X)\n",
        "\n",
        "print(\"T-Learner\", effect_t.mean())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "u-MPXGFB9wRn",
        "outputId": "24f93e37-8d91-4fdc-be3a-e42cc8ee9326"
      },
      "execution_count": 73,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "T-Learner -334.57525917807845\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# X_learner\n",
        "d1 = Y[T==1] - model_control.predict(X[T==1])\n",
        "d0 = model_treated.predict(X[T==0]) - Y[T==0]\n",
        "\n",
        "effect_x = np.concatenate([d1, d0])\n",
        "\n",
        "print(\"X-Learner\", effect_x.mean())"
      ],
      "metadata": {
        "colab": {
